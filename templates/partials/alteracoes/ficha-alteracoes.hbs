<div class="alteracoes-dados">
    <h1 class="titulo">ALTERAR DADOS</h1>
    
    <div class="">
        <h2 class="subtitulo">MESTIÇA</h2>
    </div>

    <div class="campo-alteracao">
        <label class="label-alteracao">Energia Máx.:</label>
        <input id="alt-energia-max" class="input-alt-max" value="{{actor.system.mestica.energia.max}} / {{actor.system.mestica.energia.value}}"/>
        <label class="label-positivo">+ ({{actor.system.mestica.energia.positivo}})</label>
        <input id="alt-energia-positivo" class="input-alt-positivo" value="0" placeholder="soma"/>
        <label class="label-negativo">− ({{actor.system.mestica.energia.negativo}})</label>
        <input id="alt-energia-negativo" class="input-alt-negativo" value="0" placeholder="subtrai"/>
    </div>
    <div class="campo-alteracao">
        <label class="label-alteracao">Canalização Máx.:</label>
        <input id="alt-canalizacao-max" class="input-alt-max" value="{{actor.system.mestica.canalizacao.max}} / {{actor.system.mestica.canalizacao.value}}"/>
        <label class="label-positivo">+ ({{actor.system.mestica.canalizacao.positivo}})</label>
        <input id="alt-canalizacao-positivo" class="input-alt-positivo" value="0" placeholder="soma"/>
        <label class="label-negativo">− ({{actor.system.mestica.canalizacao.negativo}})</label>
        <input id="alt-canalizacao-negativo" class="input-alt-negativo" value="0" placeholder="subtrai"/>
    </div>

    <div class="" style="display: none;">
        <h2 class="subtitulo" style="display: none;">COMBATE</h2>
    </div>

    <div class="campo-alteracao">
        <label class="label-alteracao" style="display: none;">Dano Total:</label>
        <input id="alt-dano-total" class="" value="{{actor.system.combate.dano.total}}" disabled style="display: none;"/>
    </div>
</div>