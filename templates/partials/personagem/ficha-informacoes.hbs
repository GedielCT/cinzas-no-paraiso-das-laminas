<!-- PARTE DAS INFORMAÇÕES -->    
<div class="informacoes-gerais">
    <h1 id="titulo-informacoes" class="titulo">INFORMAÇÕES GERAIS</h1>
    <!-- CAMPO NOME -->
    <div class="campo-nome">
        <label id="label-nome-personagem">Nome:</label>
        <input id="input-nome-personagem" class="input" value="{{actor.system.informacoes.nome}}">
    </div>
    <!-- CAMPO DATA DE NASCIMENTO -->        
    <div class="campo-data-nascimento-personagem">
        <label id="label-data-nascimento-personagem">Data de Nascimento:</label>
        <input id="input-data-nascimento-personagem" type="date" class="input" value="{{actor.system.informacoes.data-nascimento}}">
    </div>
    <!-- CAMPO IDADE -->        
    <div class="campo-idade-personagem">
        <label id="label-idade-personagem">Idade:</label>
        <input id="input-idade-personagem" class="input" value="{{actor.system.informacoes.idade}}">
    </div>        
    <!-- CAMPO ALTURA -->
    <div class="campo-altura">
        <label id="label-altura">Altura:</label>
        <input id="input-altura" class="input" value="{{actor.system.informacoes.altura}}">
    </div>
    <!-- CAMPO PESO -->
    <div class="campo-peso-personagem">
        <label id="label-peso-personagem">Peso:</label>
        <input id="input-peso-personagem" class="input" value="{{actor.system.informacoes.peso}}">
    </div>    
    <!-- CAMPO DATA ATUAL -->
    <div class="campo-data-atual">
        <label id="label-data-atual">Data Atual:</label>
        <input id="input-data-atual" type="date" class="input" value="{{actor.system.informacoes.data-atual}}">
    </div>
    <!-- CAMPO DINHEIRO -->
    <div class="campo-dinheiro">
        <label id="label-dinheiro">Dinheiro:</label>
        <input id="input-dinheiro" class="input" value="{{actor.system.informacoes.dinheiro}}">
    </div>
    <!-- CAMPO MÃO DOMINANTE -->
    <div class="campo-mao-dominante">
        <label id="label-mao-dominante">Mão Dominante:</label>
        <input id="input-mao-dominante" class="input" value="{{actor.system.informacoes.mao-dominante}}">
    </div>  
    <!-- CAMPO GEAS -->
    <div class="campo-geas">
        <label id="label-geas">Geas:</label>
        <input id="input-geas" class="input" value="{{actor.system.informacoes.geas}}" type="password">
    </div>
</div>
<!-- FIM DAS INFORMAÇÕES -->
<!-- INICIO STATUS -->
<div class="status">        
    <h1 class="titulo">STATUS</h1>
    <div class="geral-status">
        <!-- CAMPO VIDA -->
        <div id="vida" class="campo-status">
            <label id="label-vida" class="label-status">Vida:</label>
            <input id="input-vida" class="input-status" value="{{actor.system.status.vida.value}} / {{actor.system.status.vida.max}}" disabled/>
        </div>
        <!-- CAMPO ESTAMINA -->
        <div id="estamina" class="campo-status">
            <label id="label-estamina" class="label-status">Estamina:</label>
            <input id="input-estamina" class="input-status" value="{{actor.system.status.estamina.value}} / {{actor.system.status.estamina.max}}" disabled/>
        </div>
        <!-- CAMPO PSIQUE -->
        <div id="psique" class="campo-status">
            <label id="label-psique" class="label-status">Psique:</label>
                <input id="input-psique" class="input-status" value="{{actor.system.status.psique.value}} / {{actor.system.status.psique.max}}" disabled/>
        </div>
        <!-- CAMPO RESISTENCIA PASSIVA -->
        <div id="resist-pas" class="campo-status">
            <label id="label-resist-pas" class="label-status">Resist. Pas.:</label>
            <input id="input-resist-pas" class="input-status" value="{{actor.system.status.resist-pas.value}}" disabled/>
        </div>
        <!-- CAMPO PERCEPÇÃO PASSIVA -->
        <div id="percep-pas" class="campo-status">
            <label id="label-percep-pas" class="label-status">Perce. Pas.:</label>
            <input id="input-percep-pas" class="input-status" value="{{actor.system.status.percep-pas.value}}" disabled/>
        </div>
        <!-- CAMPO ESQUIVA PASSIVA -->
        <div id="esquiva-pas" class="campo-status">
            <label id="label-esquiva-pas" class="label-status">Esqui. Pas.:</label>
            <input id="input-esquiva-pas" class="input-status" value="{{actor.system.status.esquiva-pas.value}}" disabled/>
        </div>
    </div>
</div>
<!-- FIM STATUS -->
<!-- INICIO DOS ATRIBUTOS -->
<div class="atributo">
    <h1 class="titulo">ATRIBUTOS</h1>
    <div class="geral-atributo">
        <!-- CAMPO FORÇA -->        
        <div id="forca" class="campo-atributo">
            <label id="dado-forca" class="label-dado">({{actor.system.atributos.forca.dados}})</label>
            <label id="label-forca" class="label-atributo">Força:</label>
            <input id="input-forca" class="input-atributo" value="{{actor.system.atributos.forca.value}}"> 
        </div>
        <!-- CAMPO CONSTITUIÇÃO -->
        <div id="constituicao" class="campo-atributo">
