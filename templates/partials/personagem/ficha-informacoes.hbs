            <label id="label-constituicao" class="label-atributo">Constituição:</label>
            <input id="input-constituicao" class="input-atributo" value="{{actor.system.atributos.constituicao.value}}"/>
        </div>
        <!-- CAMPO DESTREZA -->        
        <div id="destreza" class="campo-atributo">
            <label id="dado-destreza" class="label-dado">({{actor.system.atributos.destreza.dados}})</label>
            <label id="label-destreza" class="label-atributo">Destreza:</label>
            <input id="input-destreza" class="input-atributo" value="{{actor.system.atributos.destreza.value}}"/>
        </div>
        <!-- CAMPO AGILIDADE -->        
        <div id="mobilidade" class="campo-atributo">
            <label id="dado-mobilidade" class="label-dado">({{actor.system.atributos.mobilidade.dados}})</label>
            <label id="label-mobilidade" class="label-atributo">Mobilidade:</label>
            <input id="input-mobilidade" class="input-atributo" value="{{actor.system.atributos.mobilidade.value}}">
        </div>
        <!-- CAMPO MENTE-->        
        <div id="mente" class="campo-atributo">
            <label id="dado-mente" class="label-dado">({{actor.system.atributos.mente.dados}})</label>
            <label id="label-mente" class="label-atributo">Mente:</label>
            <input id="input-mente" class="input-atributo" value="{{actor.system.atributos.mente.value}}">
        </div>
        <!-- CAMPO MORAL -->        
        <div id="moral" class="campo-atributo">
            <label id="dado-moral" class="label-dado">({{actor.system.atributos.moral.dados}})</label>
            <label id="label-moral" class="label-atributo">Moral:</label>
            <input id="input-moral" class="input-atributo" value="{{actor.system.atributos.moral.value}}">
        </div>
    </div>
</div>
<!-- FIM DOS ATRIBUTOS -->
<!-- INICIO COMBATE -->
<div class="combate">
    <h1 id="titulo-combate" class="titulo">COMBATE</h1>
    <div class="geral-dano">
        <!-- SUBTITULO DANO -->
        <div id="subtitulo-dano" class="campo-subtitulo">
            <h2 class="subtitulo">DANO</h2>
            <button id="btn-dano" class="btn-subtitulo">🗑️</button>
        </div>
        <!-- CAMPO RECEBIDO -->
        <div id="recebido" class="campo-combate">
            <label id="label-dano-recebido" class="label-combate">Recebido:</label>
            <input id="input-dano-recebido" class="input-combate" value="{{actor.system.combate.dano.recebido}}"/>
        </div>
        <!-- CAMPO ESTAMINA -->
        <div id="estamina" class="campo-combate">
            <label id="label-dano-estamina" class="label-combate">Estamina:</label>
            <input id="input-dano-estamina" class="input-combate" value="{{actor.system.combate.dano.estamina}}"/>
        </div>
        <!-- CAMPO PSIQUE -->
        <div id="psique" class="campo-combate">
            <label id="label-dano-psique" class="label-combate">Psique:</label>
            <input id="input-dano-psique" class="input-combate" value="{{actor.system.combate.dano.psique}}"/>
        </div>
        <!-- CAMPO TOTAL -->
        <div id="total" class="campo-combate">
            <label id="label-dano-total" class="label-combate">Total:</label>
            <input id="input-dano-total" class="input-combate" value="{{actor.system.combate.dano.total}}" disabled/>
        </div>
        <!-- CAMPO PORCENTAGEM -->
        <div id="porcentagem" class="campo-combate">
            <label id="label-dano-porcentagem" class="label-combate">% DANO:</label>
            <input id="input-dano-porcentagem" class="input-combate" value="{{actor.system.combate.dano.porcentagem}}" disabled/>
        </div>
    </div>
    <div class="geral-cura">
        <!-- SUBTITULO OUTRO-->
        <div id="subtitulo-outro" class="campo-subtitulo">
            <h2 class="subtitulo">RECUPERAR</h2>
            <button id="btn-outro" class="btn-subtitulo" style="display: none;">🗑️</button>
        </div>
        <!-- CAMPO CURA -->
        <div id="cura-vida" class="campo-combate">
            <label id="label-cura-vida" class="label-combate">Vida:</label>
            <input id="input-cura-vida" class="input-combate" value="{{actor.system.combate.recuperacao.vida}}"/>
        </div>
        <!-- CAMPO ESTAMINA -->
        <div id="cura-estamina" class="campo-combate">
            <label id="label-cura-estamina" class="label-combate">Estamina:</label>
            <input id="input-cura-estamina" class="input-combate" value="{{actor.system.combate.recuperacao.estamina}}"/>
        </div>
        <!-- CAMPO CURA -->
        <div id="cura-psique" class="campo-combate">
            <label id="label-cura-psique" class="label-combate">Psique:</label>
            <input id="input-cura-psique" class="input-combate" value="{{actor.system.combate.recuperacao.psique}}"/>
        </div>
        <!-- SUBTITULO RODADA-->
        <div id="subtitulo-rodada" class="campo-subtitulo">
            <h2 class="subtitulo">RODADA</h2>
            <button id="btn-rodada" class="btn-subtitulo">🗑️</button>
        </div>
        <!-- CAMPO RODADA -->
        <div id="rodada" class="campo-combate">
            <label id="label-rodada" class="label-combate">Rodada: </label>
            <input id="input-rodada" class="input-combate"/>
        </div>   
    </div>
</div>
<!-- FIM DO COMBATE -->